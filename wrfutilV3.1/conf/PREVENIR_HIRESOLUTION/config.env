#### Estructura de directorios del experimento ###
export BASEDIR=__BASEDIR__                                                                             #Basedir is when calling the experiment creation scripts
export NAMELIST=$BASEDIR/namelist/
export SCALEDIR=$BASEDIR/SCALE                                                                           # Directorio del SCALE dentro del EXP
export SCALEPPDIR=$BASEDIR/SCALE_pp                                                                      # Directorio del SCALE_init and SCALE_pp dentro del EXP
export WRFDIR=$BASEDIR/WRF                                                                             # Directorio del WRF dentro del EXP
export WPSDIR=$BASEDIR/WPS                                                                             # Directorio del WPS dentro del EXP
export WRFDADIR=$BASEDIR/WRFDA                                                                         # Directorio del WRFDA dentro del EXP
export NAMELISTDIR=$BASEDIR/NAMELIST                                                                   # Directorio de los namelist dentro del EXP
export PROCSDIR=$BASEDIR/PROCS                                                                         # Directorio donde se generan los procesos
export FCST=$BASEDIR/FCST                                                                              # Directorio del UPP dentro del EXP
export LETKFDIR=$BASEDIR/LETKF                                                                         # Direcorios donde estan las cosas del letkf de miyoshi
export OBSOPEDIR=$BASEDIR/OBSOPE                                                                       # Observation operator directory
export OBSDIR=$BASEDIR/OBS                                                                             # Donde estan las observaciones
export LOGDIR=$BASEDIR/LOGS                                                                            # Donde se van a crear los logs.
export HISTDIR=$BASEDIR/HIST                                                                           # Donde se van a archivar los resultados
export PERTDIR=$BASEDIR/PERT
